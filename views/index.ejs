<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head.ejs") %>
    <title>Index</title>
  </head>
  <body>
    <% if (locals.user) {%>
        <h1>Welcome <%= user.first_name %></h1>
        <a href="/logout">LOG OUT</a>
        <% if (!user.membership_status) {%>
          <h2>Get inside access</h2>
          <p>You can now see messages, but if you want to create messages you need to be an insider. Enter the super secret password below to get in!</p>
          <form action="/inside-access" method="POST">
             <label for="password">Super Secret Password</label>
            <input id="password" name="password" type="password" />
          </form>
        <%}%>
      <%}%>
  </body>
</html>
